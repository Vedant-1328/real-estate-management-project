# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=supplier_mgmt
DB_USER=root
DB_PASS=

# JWT (use 64+ random characters each in production)
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars_recommended_for_production_use
JWT_REFRESH_SECRET=change_me_refresh_secret_different_from_access_secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Billing PDF header
SUPPLIER_COMPANY_NAME=SHREE SAI EARTH MOVERS

# AES-256-GCM encryption for sensitive DB fields (64-char hex = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char-hex-from: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
FIELD_ENCRYPTION_ENABLED=true
