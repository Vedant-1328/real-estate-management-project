# Production environment — copy to .env and fill in real values

NODE_ENV=production
PORT=3000

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=https://your-domain.com

# MySQL
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=supplier_mgmt
DB_USER=supplier_app
DB_PASS=change_me_strong_password

# JWT — use cryptographically random strings (min 64 characters each)
JWT_ACCESS_SECRET=replace_with_64_plus_char_random_access_secret_string_here_xxxxxxxx
JWT_REFRESH_SECRET=replace_with_different_64_plus_char_random_refresh_secret_yyyyyyyy
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# PDF invoice header
SUPPLIER_COMPANY_NAME=SHREE SAI EARTH MOVERS
